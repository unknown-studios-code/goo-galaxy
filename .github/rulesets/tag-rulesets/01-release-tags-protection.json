{
  "enforcement": "active",
  "name": "Release Tag Protection",
  "target": "tag",
  "bypass_actors": [
    {
      "actor_id": 5,
      "actor_type": "RepositoryRole",
      "bypass_mode": "always"
    }
  ],
  "conditions": {
    "ref_name": {
      "exclude": [],
      "include": ["refs/tags/v*"]
    }
  },
  "rules": [
    {
      "type": "creation"
    },
    {
      "type": "deletion"
    },
    {
      "type": "update"
    },
    {
      "type": "required_signatures"
    }
  ]
}
